# Django backend environment
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
# Comma separated origins allowed to call the API (the Next.js app)
CORS_ALLOWED_ORIGINS=http://localhost:3000
# AI extraction webhook. Django calls this with the invoice image and expects
# the Smart Compta extraction JSON back (the Make scenario must end with a
# "Webhook Response" module). Markdown ```json fences in the reply are tolerated.
WEBHOOK_URL=https://hook.we.make.com/your-scenario-id
# How the image reaches the webhook: "base64" (JSON data URI — works with the
# Make/Integromat vision scenario) or "multipart" (binary file field).
WEBHOOK_IMAGE_MODE=base64

# Cloudinary media storage (avatars, invoice images). Format:
#   cloudinary://<api_key>:<api_secret>@<cloud_name>
# Leave empty to store media on local disk (dev). Set on Render for persistence.
CLOUDINARY_URL=cloudinary://592961392315689:YOUR_API_SECRET@dndwucmgr
